<?xml version='1.0' encoding='utf-8'?>
<faces-config xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-facesconfig_2_0.xsd" version="2.0">
    <managed-bean>
        <managed-bean-name>BanqueBean</managed-bean-name>
        <managed-bean-class>com.tn.shell.ui.banque.BanqueBean</managed-bean-class>
        <managed-bean-scope>session</managed-bean-scope>
        <managed-property>
            <property-name>serviceBanque</property-name>
            <value>#{ServiceBanque}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceCompte</property-name>
            <value>#{ServiceCompte}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceTransaction</property-name>
            <value>#{ServiceTransaction}</value>
        </managed-property>
    </managed-bean>
    <managed-bean>
        <managed-bean-name>CompteBean</managed-bean-name>
        <managed-bean-class>com.tn.shell.ui.banque.CompteBean</managed-bean-class>
        <managed-bean-scope>session</managed-bean-scope>
        <managed-property>
            <property-name>serviceCompte</property-name>
            <value>#{ServiceCompte}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceBanque</property-name>
            <value>#{ServiceBanque}</value>
        </managed-property>
    </managed-bean>
    <navigation-rule>
        <navigation-case>
            <from-action>#{LoginBean.logintobanque}</from-action>
            <from-outcome>correct</from-outcome>
            <to-view-id>/SHELL-banque/index.xhtml</to-view-id>
            <redirect />
        </navigation-case>
        <navigation-case>
            <from-action>#{LoginBean.logintobanque}</from-action>
            <from-outcome>incorrect</from-outcome>
            <to-view-id>/SHELL-banque/unsecure/login.xhtml</to-view-id>
            <redirect />
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <navigation-case>
            <from-action>#{AccueilBean.banque}</from-action>
            <from-outcome>success</from-outcome>
            <to-view-id>/SHELL-banque/index.xhtml</to-view-id>
            <redirect />
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <navigation-case>
            <from-action>#{BanqueBean.nouveauBanque}</from-action>
            <from-outcome>success</from-outcome>
            <to-view-id>/SHELL-banque/index.xhtml</to-view-id>
            <redirect>
                <view-param>
                    <name>view</name>
                    <value>nouveauBanque</value>
                </view-param>
            </redirect>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
