<?xml version='1.0' encoding='utf-8'?>
<faces-config xmlns="http://java.sun.com/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-facesconfig_2_0.xsd" version="2.0">
    <application>
        <el-resolver>org.springframework.web.jsf.el.SpringBeanFacesELResolver</el-resolver>
        <locale-config>
            <default-locale>fr</default-locale>
        </locale-config>
        <resource-bundle>
            <base-name>messages</base-name>
            <var>msg</var>
        </resource-bundle>
    </application>
    <managed-bean>
        <managed-bean-name>LoginBean</managed-bean-name>
        <managed-bean-class>com.tn.shell.ui.gestat.LoginBean</managed-bean-class>
        <managed-bean-scope>session</managed-bean-scope>
        <managed-property>
            <property-name>authenticationManager</property-name>
            <value>#{authenticationManager}</value>
        </managed-property>
        <managed-property>
            <property-name>userService</property-name>
            <value>#{UserService}</value>
        </managed-property>
        <managed-property>
            <property-name>servicerole</property-name>
            <value>#{ServiceRole}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceBanque</property-name>
            <value>#{ServiceBanque}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceProduit</property-name>
            <value>#{ServiceProduit}</value>
        </managed-property>
    </managed-bean>
    <managed-bean>
        <managed-bean-name>AccueilBean</managed-bean-name>
        <managed-bean-class>com.tn.shell.ui.paie.Accueil</managed-bean-class>
        <managed-bean-scope>session</managed-bean-scope>
        <managed-property>
            <property-name>serviceProduit</property-name>
            <value>#{ServiceProduit}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceLignevente</property-name>
            <value>#{ServiceLignevente}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceEmployee</property-name>
            <value>#{ServiceEmployee}</value>
        </managed-property>
        <managed-property>
            <property-name>serviceLignetransfert</property-name>
            <value>#{ServiceLigneAlimentation}</value>
        </managed-property>
    </managed-bean>
    <navigation-rule>
        <navigation-case>
            <from-action>#{LoginBean.login}</from-action>
            <from-outcome>correct</from-outcome>
            <to-view-id>/index.xhtml</to-view-id>
            <redirect />
        </navigation-case>
        <navigation-case>
            <from-action>#{LoginBean.login}</from-action>
            <from-outcome>incorrect</from-outcome>
            <to-view-id>/unsecure/login.xhtml</to-view-id>
            <redirect />
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <navigation-case>
            <from-action>#{LoginBean.logout}</from-action>
            <from-outcome>loggedout</from-outcome>
            <to-view-id>/unsecure/login.xhtml</to-view-id>
            <redirect />
        </navigation-case>
    </navigation-rule>
</faces-config>